# pnpm security config — supply chain attack mitigation

# Only install packages published 24+ hours ago (1440 min)
# Blocks freshly compromised versions before they get caught
minimum-release-age=1440

# Auto-install peer deps (cleaner installs)
auto-install-peers=true

# Strict peer deps — fail on missing peers
strict-peer-dependencies=false

# Lock to the registry default (cosmetic, explicit)
registry=https://registry.npmjs.org/
