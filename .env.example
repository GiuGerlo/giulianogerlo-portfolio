# Plantilla de variables de entorno — ESTE archivo SÍ se commitea.
# Copialo a `.env` y completá los valores reales:
#   cp .env.example .env
# El `.env` real está en .gitignore y nunca se sube al repo.

# --- Cloudflare Turnstile (anti-bot) ---
# SITE KEY: pública, va en el frontend. Prefijo VITE_ para exponerla al
# bundle del browser. Se obtiene en el dashboard de Cloudflare Turnstile.
VITE_TURNSTILE_SITE_KEY=

# SECRET KEY: privada, solo server-side (serverless function). SIN VITE_.
TURNSTILE_SECRET_KEY=

# --- Resend (envío de emails) ---
# API key privada, solo server-side. SIN prefijo VITE_.
# Se obtiene en el dashboard de Resend (resend.com/api-keys).
RESEND_API_KEY=
