# Plantilla de variables de entorno — ESTE archivo SÍ se commitea.
# Copialo a `.env` y completá los valores reales:
#   cp .env.example .env
# El `.env` real está en .gitignore y nunca se sube al repo.

# --- Cloudflare Turnstile (anti-bot) ---
# SITE KEY: pública, va en el frontend. Prefijo VITE_ para exponerla al
# bundle del browser. Se obtiene en el dashboard de Cloudflare Turnstile.
VITE_TURNSTILE_SITE_KEY=

# SECRET KEY: privada, solo server-side (serverless function). SIN VITE_.
TURNSTILE_SECRET_KEY=

# --- Resend (envío de emails) ---
# API key privada, solo server-side. SIN prefijo VITE_.
# Se obtiene en el dashboard de Resend (resend.com/api-keys).
RESEND_API_KEY=

# Destino del email de contacto (a dónde llegan los mensajes del form).
CONTACT_EMAIL_TO=

# Remitente. Sin dominio propio verificado usar onboarding@resend.dev.
CONTACT_EMAIL_FROM=

# --- Upstash Redis (rate limiting del form) ---
# Store creado en el dashboard de Vercel (Storage -> Upstash for Redis).
# La integración inyecta varias vars; solo se usan estas dos (REST API).
# En producción Vercel las inyecta solas; en local copiarlas a mano.
# Solo server-side, SIN prefijo VITE_.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Google Gemini (chatbot "Preguntale a Giuliano", Phase 11) ---
# API key privada, solo server-side. SIN prefijo VITE_.
# Free tier sin tarjeta. Se obtiene en Google AI Studio (aistudio.google.com).
GEMINI_API_KEY=

# --- Supabase (Phase 12 — backend dinámico + admin) ---
# Project URL: pública, va en el frontend. Prefijo VITE_.
# Settings -> API -> Project URL.
VITE_SUPABASE_URL=

# Anon key: pública por diseño, va en el frontend. RLS la protege.
# Settings -> API -> anon public.
VITE_SUPABASE_ANON_KEY=

# Service role key: PRIVADA, solo server-side (scripts/seed + api/*).
# Bypassa RLS — si se filtra al frontend = acceso total a la DB.
# Settings -> API -> service_role (revelar con click). SIN prefijo VITE_.
SUPABASE_SERVICE_ROLE_KEY=


# --- GitHub API  ---
GITHUB_TOKEN=