# Environment variables — NEVER commit secrets
.env
.env.*
!.env.example

# Test coverage
coverage

# Vercel
.vercel

# CodeGraph (índice local, no commitear)
.codegraph

# Claude Code — versionar la estructura compartida (rules/, commands/, agents/,
# hooks/, settings.json, CLAUDE.md) para que sincronice entre PCs vía git.
# Fuera de git: config local per-PC, datos de sesión/auth, y las SKILLS.
.claude/settings.local.json
.claude.json
# Skills: se versionan como carpetas REALES en .claude/skills/ (convertidas de los
# symlinks que crea skills.sh) para que sincronicen entre PCs — git en Windows tiene
# core.symlinks=false, así que un symlink commiteado se rompería en la otra PC.
# .agents/ es el store interno de skills.sh (metadata local) — ese NO va a git.
.agents/
# OS
Thumbs.db

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Skills/agents (otras herramientas — NO tocar .claude que sí se versiona)
.kiro
skills-lock.json
opencode.jsonc

# Solo el AGENTS.md de la raíz se ignora; los AGENTS.md internos de las skills
# (composition-patterns, react-best-practices) SÍ se versionan.
/AGENTS.md